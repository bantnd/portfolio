{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "build": {
    "env": {
      "GO_BUILD_FLAGS": "-ldflags '-s -w'"
    }
  },
  "experimentalServices": {
    "web": {
      "entrypoint": ".",
      "framework": "astro",
      "routePrefix": "/"
    },
    "api": {
      "entrypoint": "server",
      "framework": "go",
      "routePrefix": "/api"
    }
  }
}
