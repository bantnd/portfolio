---
import { about } from "../consts";

interface Props {
    duration?: number; // Duration in milliseconds before auto-dismiss
}

const { duration = 2500 } = Astro.props;
---

<!-- Stardust Overlay - SEO-safe: real content loads behind this -->
<div id="stardust-overlay" class="stardust-overlay" data-duration={duration}>
    <canvas id="stardust-canvas"></canvas>
    <div class="stardust-content">
        <h1 class="stardust-title">Ban Tran</h1>
        <p class="stardust-subtitle">{about.tagLine}</p>
        <p class="stardust-hint">Click or wait to continue...</p>
    </div>
</div>

<style>
    .stardust-overlay {
        position: fixed;
        inset: 0;
        z-index: 9999;
        background: linear-gradient(
            135deg,
            #0a0a0f 0%,
            #0d1117 50%,
            #0a0a0f 100%
        );
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition:
            opacity 0.8s ease-out,
            visibility 0.8s ease-out;
    }

    .stardust-overlay.hidden {
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
    }

    #stardust-canvas {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
    }

    .stardust-content {
        position: relative;
        z-index: 1;
        text-align: center;
        animation: fadeInUp 1s ease-out 0.3s both;
    }

    .stardust-title {
        font-size: clamp(2.5rem, 8vw, 5rem);
        font-weight: 700;
        background: linear-gradient(
            135deg,
            #ffffff 0%,
            #a78bfa 50%,
            #22d3ee 100%
        );
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        text-shadow: 0 0 60px rgba(167, 139, 250, 0.3);
        margin: 0;
        letter-spacing: -0.02em;
    }

    .stardust-subtitle {
        font-size: clamp(1rem, 3vw, 1.5rem);
        color: rgba(255, 255, 255, 0.7);
        margin-top: 0.5rem;
        font-weight: 400;
        letter-spacing: 0.05em;
    }

    .stardust-hint {
        font-size: 0.875rem;
        color: rgba(255, 255, 255, 0.4);
        margin-top: 2rem;
        animation: pulse 2s ease-in-out infinite;
    }

    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @keyframes pulse {
        0%,
        100% {
            opacity: 0.4;
        }
        50% {
            opacity: 0.8;
        }
    }
</style>

<script>
    import { Particle } from '../lib/particles';
    import type { ParticleConfig } from '../lib/particles';
    class StardustAnimation {
        private canvas: HTMLCanvasElement;
        private ctx: CanvasRenderingContext2D;
        private particles: Particle[] = [];
        private animationId: number = 0;
        private mouseX: number = 0;
        private mouseY: number = 0;

        constructor(canvas: HTMLCanvasElement) {
            this.canvas = canvas;
            this.ctx = canvas.getContext("2d")!;
            this.resize();
            this.init();
            this.animate();

            window.addEventListener("resize", () => this.resize());
            window.addEventListener("mousemove", (e) => {
                this.mouseX = e.clientX;
                this.mouseY = e.clientY;
            });
        }

        resize() {
            this.canvas.width = window.innerWidth;
            this.canvas.height = window.innerHeight;
        }

        init() {
            const particleCount = Math.min(
                150,
                Math.floor((window.innerWidth * window.innerHeight) / 8000),
            );

            for (let i = 0; i < particleCount; i++) {
                this.particles.push(
                    new Particle({
                        canvasWidth: this.canvas.width,
                        canvasHeight: this.canvas.height,
                    }),
                );
            }
        }

        animate() {
            this.ctx.fillStyle = "rgba(10, 10, 15, 0.1)";
            this.ctx.fillRect(0, 0, this.canvas.width, this.canvas.height);

            this.particles.forEach((particle, index) => {
                particle.update(this.mouseX, this.mouseY);
                particle.draw(this.ctx);

                // Create connections between nearby particles
                for (let j = index + 1; j < this.particles.length; j++) {
                    const dx = particle.x - this.particles[j].x;
                    const dy = particle.y - this.particles[j].y;
                    const distance = Math.sqrt(dx * dx + dy * dy);

                    if (distance < 100) {
                        this.ctx.beginPath();
                        this.ctx.strokeStyle = `rgba(167, 139, 250, ${0.15 * (1 - distance / 100)})`;
                        this.ctx.lineWidth = 0.5;
                        this.ctx.moveTo(particle.x, particle.y);
                        this.ctx.lineTo(
                            this.particles[j].x,
                            this.particles[j].y,
                        );
                        this.ctx.stroke();
                    }
                }
            });

            this.animationId = requestAnimationFrame(() => this.animate());
        }

        destroy() {
            cancelAnimationFrame(this.animationId);
        }
    }



    // Initialize
    const overlay = document.getElementById(
        "stardust-overlay",
    ) as HTMLDivElement;
    const canvas = document.getElementById(
        "stardust-canvas",
    ) as HTMLCanvasElement;
    const duration = parseInt(overlay.dataset.duration || "2500");

    // Check if user has already seen the intro (using sessionStorage for per-session)
    const hasSeenIntro = sessionStorage.getItem("seenIntro");

    if (hasSeenIntro) {
        // Skip animation if already seen this session
        overlay.classList.add("hidden");
    } else {
        const stardust = new StardustAnimation(canvas);

        const dismissOverlay = () => {
            overlay.classList.add("hidden");
            sessionStorage.setItem("seenIntro", "true");
            setTimeout(() => {
                stardust.destroy();
                overlay.remove();
            }, 800);
        };

        // Auto-dismiss after duration
        setTimeout(dismissOverlay, duration);

        // Click/touch to skip
        overlay.addEventListener("click", dismissOverlay);
        overlay.addEventListener("touchstart", dismissOverlay, {
            passive: true,
        });

        // Also dismiss on scroll attempt
        window.addEventListener("wheel", dismissOverlay, {
            once: true,
            passive: true,
        });
        window.addEventListener(
            "keydown",
            (e) => {
                if (e.key === "Escape" || e.key === " " || e.key === "Enter") {
                    dismissOverlay();
                }
            },
            { once: true },
        );
    }
</script>
