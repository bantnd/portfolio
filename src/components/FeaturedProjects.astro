---
import { Image } from "astro:assets";
import { projects } from "../consts";
import Icon from "./Icon.astro";
---

<section class="mt-20 lg:mt-32">
  <div class="mb-10 flex items-center justify-between px-2 md:px-8">
    <div>
      <h2 class="mb-2">
        <span class="fancy-highlight">Featured Projects</span>
      </h2>
      <p class="text-muted text-sm uppercase tracking-widest font-bold opacity-60">Technical Work & Experiments</p>
    </div>
    <a href="/projects" class="btn btn-soft btn-sm group light-mode-subtle">
      View All <Icon name="ArrowRight" size="1.1rem" class="transition-transform group-hover:translate-x-1" />
    </a>
  </div>

  <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
    {
      projects.slice(0, 3).map((proj, index) => (
        <div class="group relative flex flex-col rounded-3xl border border-base-content/10 bg-base-content/[0.03] p-8 shadow-2xl transition-all duration-300 hover:-translate-y-2 hover:border-accent/30 hover:bg-base-content/[0.07] hover:shadow-accent/5">
          {/* Glassy background glow on hover */}
          <div class="pointer-events-none absolute -inset-px rounded-3xl bg-gradient-to-br from-accent/10 to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100" />
          
          <div class="relative z-10">
            <div class="mb-6 flex h-14 w-14 items-center justify-center rounded-2xl bg-white/5 p-3 shadow-inner ring-1 ring-white/10 transition-transform duration-300 group-hover:scale-110">
              {typeof proj.logoImage === "string" ? (
                <img
                  src={proj.logoImage}
                  alt={proj.title}
                  class={`h-full w-full object-contain ${proj.title.includes("Kafka") ? "kafka-logo" : ""}`}
                />
              ) : (
                <Image
                  src={proj.logoImage}
                  alt={proj.title}
                  class={`h-full w-full object-contain ${proj.title === "High-Availability Kubernetes Platform" ? "kafka-logo" : ""}`}
                />
              )}
            </div>
            
            <h3 class="text-2xl font-bold tracking-tight text-base-content transition-colors group-hover:text-accent">{proj.title}</h3>
            
            <div class="mt-3 flex flex-wrap gap-2">
              {proj.techs.slice(0, 3).map((tech) => (
                <span class="rounded-full border border-accent/20 bg-accent/5 px-3 py-1 text-[10px] font-semibold tracking-wider text-accent uppercase">
                  {tech}
                </span>
              ))}
              {proj.techs.length > 3 && (
                <span class="rounded-full border border-white/5 bg-white/5 px-3 py-1 text-[10px] font-semibold tracking-wider text-muted uppercase">
                  +{proj.techs.length - 3}
                </span>
              )}
            </div>
            
            <p class="text-muted mt-5 mb-8 line-clamp-3 text-sm leading-relaxed">
              {proj.description}
            </p>
            
            <div class="mt-auto">
              <a
                href={proj.liveHref || proj.sourceHref || "/projects"}
                class="group/link inline-flex items-center gap-2 text-sm font-bold tracking-wide text-accent"
              >
                <span class="relative">
                  Learn More
                  <span class="absolute -bottom-1 left-0 h-px w-0 bg-accent transition-all duration-300 group-hover/link:w-full" />
                </span>
                <Icon name="ArrowRight" size="1.1rem" class="transition-transform duration-300 group-hover/link:translate-x-1" />
              </a>
            </div>
          </div>
        </div>
      ))
    }
  </div>
</section>
