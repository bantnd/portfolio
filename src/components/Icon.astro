---
import {
  ArrowRight,
  Briefcase,
  FileText,
  Github,
  Linkedin,
  Mail,
  Send,
} from "@lucide/astro";

interface Props {
  name: string;
  size?: string | number;
  class?: string;
}

const { name, size = "1.25rem", class: className } = Astro.props;

const iconMap = {
  ArrowRight,
  Briefcase,
  FileText,
  Github,
  Linkedin,
  Mail,
  Send,
};

const IconComponent = iconMap[name as keyof typeof iconMap];
---

{IconComponent && <IconComponent size={size} class={className} />}
