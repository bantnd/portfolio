---
// Fireworks Theme - Click to explode
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>🎆 Fireworks</title>
        <meta name="robots" content="noindex, nofollow" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <style>
            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }
            body {
                font-family: "Inter", system-ui, sans-serif;
                background: linear-gradient(180deg, #0a0a1a 0%, #0f0f2a 100%);
                min-height: 100vh;
                overflow: hidden;
                cursor: crosshair;
            }
            canvas {
                position: fixed;
                inset: 0;
                width: 100%;
                height: 100%;
            }
            .content {
                position: fixed;
                inset: 0;
                display: flex;
                flex-direction: column;
                align-items: center;
                justify-content: center;
                z-index: 10;
                pointer-events: none;
            }
            .title {
                font-size: clamp(2.5rem, 8vw, 5rem);
                font-weight: 700;
                background: linear-gradient(
                    135deg,
                    #fef3c7 0%,
                    #f59e0b 25%,
                    #ef4444 50%,
                    #ec4899 75%,
                    #8b5cf6 100%
                );
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                animation: shimmer 3s ease-in-out infinite;
            }
            .subtitle {
                font-size: 1.25rem;
                color: rgba(254, 243, 199, 0.6);
                margin-top: 0.5rem;
            }
            .hint {
                margin-top: 2rem;
                font-size: 0.875rem;
                color: rgba(255, 255, 255, 0.4);
                animation: pulse 2s ease-in-out infinite;
            }
            .nav {
                position: fixed;
                bottom: 2rem;
                left: 50%;
                transform: translateX(-50%);
                display: flex;
                gap: 1rem;
                flex-wrap: wrap;
                justify-content: center;
                z-index: 20;
            }
            .nav a {
                padding: 0.5rem 1rem;
                border: 1px solid rgba(255, 255, 255, 0.2);
                background: rgba(255, 255, 255, 0.1);
                color: white;
                border-radius: 9999px;
                font-size: 0.75rem;
                text-decoration: none;
                backdrop-filter: blur(10px);
                transition: all 0.3s;
            }
            .nav a:hover {
                background: rgba(255, 255, 255, 0.2);
            }
            .nav a.active {
                background: rgba(239, 68, 68, 0.3);
                border-color: rgba(239, 68, 68, 0.6);
            }
            @keyframes shimmer {
                0%,
                100% {
                    filter: brightness(1);
                }
                50% {
                    filter: brightness(1.2);
                }
            }
            @keyframes pulse {
                0%,
                100% {
                    opacity: 0.4;
                }
                50% {
                    opacity: 0.8;
                }
            }
        </style>
    </head>
    <body>
        <canvas id="canvas"></canvas>
        <div class="content">
            <h1 class="title">🎆 Fireworks</h1>
            <p class="subtitle">Click anywhere to celebrate!</p>
            <p class="hint">Touch or click to launch</p>
        </div>
        <nav class="nav">
            <a href="/stars">✨ Stars</a>
            <a href="/stars/fireflies">🔥 Fireflies</a>
            <a href="/stars/galaxy">🌌 Galaxy</a>
            <a href="/stars/matrix">⚡ Matrix</a>
            <a href="/stars/fireworks" class="active">🎆 Fireworks</a>
            <a href="/stars/blackhole">🕳️ Black Hole</a>
            <a href="/">← Home</a>
        </nav>

        <script>
            const canvas = document.getElementById(
                "canvas",
            ) as HTMLCanvasElement;
            const ctx = canvas.getContext("2d")!;
            let width = (canvas.width = window.innerWidth);
            let height = (canvas.height = window.innerHeight);

            interface Particle {
                x: number;
                y: number;
                vx: number;
                vy: number;
                color: string;
                life: number;
                maxLife: number;
                size: number;
                trail: { x: number; y: number }[];
            }

            interface Rocket {
                x: number;
                y: number;
                vy: number;
                targetY: number;
                color: string;
                trail: { x: number; y: number }[];
            }

            const particles: Particle[] = [];
            const rockets: Rocket[] = [];
            const gravity = 0.05;

            const colors = [
                ["#ef4444", "#f87171", "#fca5a5"], // Red
                ["#f59e0b", "#fbbf24", "#fcd34d"], // Orange
                ["#22c55e", "#4ade80", "#86efac"], // Green
                ["#3b82f6", "#60a5fa", "#93c5fd"], // Blue
                ["#8b5cf6", "#a78bfa", "#c4b5fd"], // Purple
                ["#ec4899", "#f472b6", "#f9a8d4"], // Pink
                ["#06b6d4", "#22d3ee", "#67e8f9"], // Cyan
            ];

            function launchRocket(x: number) {
                const colorSet =
                    colors[Math.floor(Math.random() * colors.length)];
                rockets.push({
                    x: x,
                    y: height,
                    vy: -12 - Math.random() * 4,
                    targetY: height * 0.2 + Math.random() * height * 0.3,
                    color: colorSet[0],
                    trail: [],
                });
            }

            function explode(x: number, y: number, colorSet: string[]) {
                const particleCount = 80 + Math.floor(Math.random() * 40);

                for (let i = 0; i < particleCount; i++) {
                    const angle =
                        (Math.PI * 2 * i) / particleCount + Math.random() * 0.2;
                    const speed = 2 + Math.random() * 4;

                    particles.push({
                        x,
                        y,
                        vx: Math.cos(angle) * speed,
                        vy: Math.sin(angle) * speed,
                        color: colorSet[
                            Math.floor(Math.random() * colorSet.length)
                        ],
                        life: 1,
                        maxLife: 60 + Math.random() * 40,
                        size: 2 + Math.random() * 2,
                        trail: [],
                    });
                }
            }

            function animate() {
                ctx.fillStyle = "rgba(10, 10, 26, 0.2)";
                ctx.fillRect(0, 0, width, height);

                // Update rockets
                for (let i = rockets.length - 1; i >= 0; i--) {
                    const r = rockets[i];
                    r.trail.unshift({ x: r.x, y: r.y });
                    if (r.trail.length > 10) r.trail.pop();

                    r.y += r.vy;
                    r.vy += gravity * 0.5;

                    // Draw trail
                    ctx.beginPath();
                    ctx.moveTo(r.x, r.y);
                    for (const t of r.trail) {
                        ctx.lineTo(t.x, t.y);
                    }
                    ctx.strokeStyle = r.color;
                    ctx.lineWidth = 2;
                    ctx.stroke();

                    // Explode at target
                    if (r.y <= r.targetY || r.vy >= 0) {
                        const colorSet =
                            colors[Math.floor(Math.random() * colors.length)];
                        explode(r.x, r.y, colorSet);
                        rockets.splice(i, 1);
                    }
                }

                // Update particles
                for (let i = particles.length - 1; i >= 0; i--) {
                    const p = particles[i];

                    p.trail.unshift({ x: p.x, y: p.y });
                    if (p.trail.length > 5) p.trail.pop();

                    p.x += p.vx;
                    p.y += p.vy;
                    p.vy += gravity;
                    p.vx *= 0.98;
                    p.vy *= 0.98;
                    p.life -= 1 / p.maxLife;

                    if (p.life <= 0) {
                        particles.splice(i, 1);
                        continue;
                    }

                    // Draw trail
                    ctx.beginPath();
                    ctx.moveTo(p.x, p.y);
                    for (let j = 0; j < p.trail.length; j++) {
                        ctx.lineTo(p.trail[j].x, p.trail[j].y);
                    }
                    ctx.strokeStyle = p.color
                        .replace(")", `, ${p.life * 0.5})`)
                        .replace("rgb", "rgba")
                        .replace("#", "rgba(")
                        .replace(
                            /([a-f0-9]{2})([a-f0-9]{2})([a-f0-9]{2})/i,
                            (_, r, g, b) =>
                                `${parseInt(r, 16)}, ${parseInt(g, 16)}, ${parseInt(b, 16)}`,
                        );
                    ctx.lineWidth = p.size * p.life;
                    ctx.stroke();

                    // Draw particle
                    ctx.fillStyle = p.color;
                    ctx.globalAlpha = p.life;
                    ctx.beginPath();
                    ctx.arc(p.x, p.y, p.size * p.life, 0, Math.PI * 2);
                    ctx.fill();
                    ctx.globalAlpha = 1;
                }

                // Auto-launch occasionally
                if (Math.random() < 0.02 && rockets.length < 3) {
                    launchRocket(Math.random() * width);
                }

                requestAnimationFrame(animate);
            }

            // Click to launch
            canvas.addEventListener("click", (e) => {
                launchRocket(e.clientX);
            });

            canvas.addEventListener("touchstart", (e) => {
                e.preventDefault();
                for (const touch of e.touches) {
                    launchRocket(touch.clientX);
                }
            });

            window.addEventListener("resize", () => {
                width = canvas.width = window.innerWidth;
                height = canvas.height = window.innerHeight;
            });

            // Initial launch
            setTimeout(() => launchRocket(width * 0.3), 500);
            setTimeout(() => launchRocket(width * 0.7), 1000);

            animate();
        </script>
    </body>
</html>
