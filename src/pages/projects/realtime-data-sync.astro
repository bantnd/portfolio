---
import Layout from "../../layouts/Layout.astro";
import { ArrowLeft } from "@lucide/astro";
---

<Layout
  title="Real-time Data Synchronization Platform | Ban Tran"
  description="Enterprise-scale data synchronization system handling millions of events daily with CDC pipelines and stream processing"
>
  <!-- Back Navigation -->
  <div class="mb-8">
    <a
      href="/projects"
      class="text-accent inline-flex items-center gap-2 hover:underline"
    >
      <ArrowLeft size="1rem" />
      Back to Projects
    </a>
  </div>

  <!-- Project Header -->
  <section class="mb-12">
    <h1 class="mb-4 text-4xl font-bold lg:text-5xl">
      <span class="fancy-highlight"
        >Real-time Data Synchronization Platform</span
      >
    </h1>
    <div class="mb-6 flex flex-wrap gap-2">
      <span class="badge badge-accent">Kafka</span>
      <span class="badge badge-accent">Debezium</span>
      <span class="badge badge-accent">Confluent Schema Registry</span>
      <span class="badge badge-accent">Materialize</span>
      <span class="badge badge-accent">Flink</span>
      <span class="badge badge-accent">RisingWave</span>
    </div>
    <p class="text-muted text-lg">
      Built enterprise-scale data synchronization system handling millions of
      events daily. Implemented CDC pipelines with Kafka and stream processing
      for real-time data transformations.
    </p>
    <!-- comment out this section to finish the blog post first-->
    <!-- <div
      class="mt-6 rounded-xl border border-blue-500/20 bg-blue-500/10 p-6 backdrop-blur-xl dark:border-blue-400/20 dark:bg-blue-400/10"
    >
      <h3 class="mb-2 text-lg font-semibold">
        📖 Read the Full Technical Deep Dive
      </h3>
      <p class="text-muted mb-4">
        Learn about the architecture, challenges, and solutions behind this
        platform in our detailed blog post.
      </p>
      <a
        href="/blog/realtime-data-sync"
        class="btn btn-accent inline-flex items-center gap-2"
      >
        Read the Blog Post
        <svg
          class="h-4 w-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M9 5l7 7-7 7"></path>
        </svg>
      </a>
    </div> -->
  </section>

  <!-- Results & Impact -->
  <section class="mb-12">
    <h2 class="mb-6">
      <span class="fancy-highlight">Results & Impact</span>
    </h2>
    <div
      class="glass-effect rounded-xl border border-white/30 p-6 dark:border-white/20"
    >
      <div class="grid gap-6 md:grid-cols-3">
        <div class="text-center">
          <div class="text-accent mb-2 text-4xl font-bold">5M+</div>
          <div class="text-muted text-sm">Events Per Day</div>
        </div>
        <div class="text-center">
          <div class="text-accent mb-2 text-4xl font-bold">&lt;100ms</div>
          <div class="text-muted text-sm">Average Latency</div>
        </div>
        <div class="text-center">
          <div class="text-accent mb-2 text-4xl font-bold">99.99%</div>
          <div class="text-muted text-sm">Uptime SLA</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Live System Status -->
  <section class="mb-12">
    <div class="mb-6 flex items-center justify-between">
      <h2>
        <span class="fancy-highlight">Live System Status</span>
      </h2>
      <button
        id="refreshBtn"
        class="btn btn-sm btn-accent light-mode-subtle"
        onclick="fetchConnectorStatus()"
      >
        <svg
          class="h-4 w-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"
          ></path>
        </svg>
        Show Status
      </button>
    </div>

    <div
      id="securityNote"
      class="mb-4 hidden rounded-lg border border-gray-500 bg-white p-3 shadow-sm dark:border-white/20 dark:bg-white/10"
    >
      <p id="securityNoteText" class="text-sm font-medium">
        <svg
          id="securityNoteIcon"
          class="mr-2 inline-block h-4 w-4"
          fill="none"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
          ></path>
        </svg>
        <strong>Note:</strong> For security reasons, all names are displayed in encrypted
        format.
      </p>
    </div>

    <div id="statusContainer" class="space-y-4">
      <!-- Status will be loaded here -->
    </div>

    <div id="errorContainer" class="hidden">
      <div
        class="rounded-xl border border-red-500/20 bg-red-500/10 p-6 backdrop-blur-xl"
      >
        <p class="font-semibold text-red-400">
          Failed to load connector status
        </p>
        <p class="mt-2 text-sm text-red-300" id="errorMessage"></p>
        <p class="mt-2 text-xs text-red-200">
          Note: This may be due to CORS restrictions. The API needs to allow
          requests from this domain.
        </p>
      </div>
    </div>
  </section>

  <!-- Back Navigation -->
  <div class="mt-12">
    <a
      href="/projects"
      class="text-accent inline-flex items-center gap-2 hover:underline"
    >
      <ArrowLeft size="1rem" />
      Back to Projects
    </a>
  </div>

  <script>
    const escapeHTML = (value) =>
      String(value ?? "").replace(
        /[&<>"']/g,
        (char) =>
          ({
            "&": "&amp;",
            "<": "&lt;",
            ">": "&gt;",
            '"': "&quot;",
            "'": "&#39;",
          })[char] || char,
      );

    const normalizeConnector = ([name, connector]) => {
      const record =
        connector && typeof connector === "object" ? connector : {};

      return {
        name: String(name),
        state: String(record.state || "UNKNOWN").trim().toUpperCase(),
        type: String(record.type || "unknown").trim().toLowerCase(),
      };
    };

    const statePriority = (state) => {
      if (state === "RUNNING") return 0;
      if (state === "PAUSED") return 1;
      return 2;
    };

    const stateTone = (state) => {
      if (state === "RUNNING") {
        return {
          dot: "bg-green-400",
          text: "text-green-400",
          border: "border-green-500/25",
          bg: "bg-green-500/10",
        };
      }
      if (state === "PAUSED") {
        return {
          dot: "bg-yellow-400",
          text: "text-yellow-400",
          border: "border-yellow-500/25",
          bg: "bg-yellow-500/10",
        };
      }
      return {
        dot: "bg-red-400",
        text: "text-red-400",
        border: "border-red-500/25",
        bg: "bg-red-500/10",
      };
    };

    const countBy = (items, key) =>
      items.reduce((counts, item) => {
        const value = item[key] || "unknown";
        counts[value] = (counts[value] || 0) + 1;
        return counts;
      }, {});

    const formatPercent = (count, total) =>
      total === 0 ? "0" : ((count / total) * 100).toFixed(1).replace(".0", "");

    const renderTypeMetric = (label, count) => `
      <div class="rounded-xl border border-white/20 bg-white/10 p-4 backdrop-blur-xl">
        <p class="text-sm text-muted">${label}</p>
        <p class="mt-2 text-3xl font-bold text-accent">${count}</p>
      </div>
    `;

    async function fetchConnectorStatus() {
      const statusContainer = document.getElementById("statusContainer");
      const errorContainer = document.getElementById("errorContainer");
      const refreshBtn = document.getElementById("refreshBtn");
      const securityNote = document.getElementById("securityNote");

      if (!statusContainer || !errorContainer || !refreshBtn) return;

      // Show security note
      if (securityNote) {
        securityNote.classList.remove("hidden");

        // Set text color based on theme
        const noteText = document.getElementById("securityNoteText");
        const noteIcon = document.getElementById("securityNoteIcon");
        const isDark =
          document.documentElement.getAttribute("data-theme") === "dark";

        if (noteText && noteIcon) {
          noteText.style.color = isDark ? "rgb(209, 213, 219)" : "black";
          noteIcon.style.stroke = isDark ? "rgb(209, 213, 219)" : "black";
        }
      }

      // Change button to Refresh mode
      refreshBtn.innerHTML = `
        <svg
          class="h-4 w-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"
          ></path>
        </svg>
        Refresh
      `;

      // Show loading state
      statusContainer.innerHTML = `
        <div class="flex items-center justify-center rounded-xl border border-white/20 bg-white/10 p-8 backdrop-blur-xl">
          <div class="flex items-center gap-3">
            <div class="h-8 w-8 animate-spin rounded-full border-4 border-accent border-t-transparent"></div>
            <p class="text-muted">Loading connector status...</p>
          </div>
        </div>
      `;
      errorContainer.classList.add("hidden");
      refreshBtn.setAttribute("disabled", "true");

      try {
        // Fetch connector status via server-side proxy
        const response = await fetch("/api/connectors");

        if (!response.ok) {
          const err = await response.json().catch(() => ({}));
          throw new Error(err.error || `API returned status ${response.status}`);
        }

        const connectors = await response.json();

        const sortedConnectors = Object.entries(connectors || {})
          .map(normalizeConnector)
          .sort((a, b) => {
            const stateDiff = statePriority(a.state) - statePriority(b.state);
            if (stateDiff !== 0) return stateDiff;
            return a.name.localeCompare(b.name);
          });

        // Display connectors
        if (sortedConnectors.length === 0) {
          statusContainer.innerHTML = `
            <div class="rounded-xl border border-white/20 bg-white/10 p-6 backdrop-blur-xl">
              <p class="text-center text-muted">No connectors found</p>
            </div>
          `;
        } else {
          const runningCount = sortedConnectors.filter(
            (connector) => connector.state === "RUNNING",
          ).length;
          const totalCount = sortedConnectors.length;
          const sourceCount = sortedConnectors.filter(
            (connector) => connector.type === "source",
          ).length;
          const sinkCount = sortedConnectors.filter(
            (connector) => connector.type === "sink",
          ).length;
          const stateCounts = countBy(sortedConnectors, "state");
          const typeCounts = countBy(sortedConnectors, "type");
          const lastChecked = new Intl.DateTimeFormat(undefined, {
            dateStyle: "medium",
            timeStyle: "medium",
          }).format(new Date());
          const allHealthy = runningCount === totalCount;
          const stateRows = Object.entries(stateCounts).sort(
            ([stateA], [stateB]) => statePriority(stateA) - statePriority(stateB),
          );
          const typeRows = Object.entries(typeCounts).sort(
            ([typeA], [typeB]) => typeA.localeCompare(typeB),
          );

          statusContainer.innerHTML = `
            <div class="rounded-xl border border-white/20 bg-white/10 p-6 backdrop-blur-xl">
              <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
                <div>
                  <p class="text-sm uppercase tracking-wide text-muted">System Status</p>
                  <p class="mt-2 text-2xl font-bold md:text-3xl">
                    ${
                      allHealthy
                        ? '<span class="text-green-400">All Systems Operational</span>'
                        : '<span class="text-yellow-400">Attention Required</span>'
                    }
                  </p>
                  <p class="mt-2 text-sm text-muted">Last checked: ${escapeHTML(lastChecked)}</p>
                </div>
                <div class="md:text-right">
                  <p class="text-4xl font-bold text-accent">${runningCount}/${totalCount}</p>
                  <p class="text-sm text-muted">running connectors</p>
                </div>
              </div>
            </div>

            <div class="grid gap-3 md:grid-cols-4">
              ${renderTypeMetric("Total connectors", totalCount)}
              ${renderTypeMetric("Source connectors", sourceCount)}
              ${renderTypeMetric("Sink connectors", sinkCount)}
              ${renderTypeMetric("Non-running", totalCount - runningCount)}
            </div>

            <div class="grid gap-4 lg:grid-cols-[1.2fr_0.8fr]">
              <div class="rounded-xl border border-white/20 bg-white/10 p-5 backdrop-blur-xl">
                <div class="mb-4 flex items-center justify-between gap-3">
                  <div>
                    <p class="text-sm uppercase tracking-wide text-muted">State Distribution</p>
                    <p class="mt-1 text-lg font-semibold">Kafka Connect health</p>
                  </div>
                  <span class="rounded bg-white/10 px-3 py-1 text-sm text-muted">${formatPercent(runningCount, totalCount)}% running</span>
                </div>
                <div class="space-y-4">
                  ${stateRows
                    .map(([state, count]) => {
                      const tone = stateTone(state);
                      const percent = formatPercent(count, totalCount);

                      return `
                        <div>
                          <div class="mb-2 flex items-center justify-between gap-3 text-sm">
                            <div class="flex items-center gap-2">
                              <span class="h-2.5 w-2.5 rounded-full ${tone.dot}"></span>
                              <span class="font-semibold ${tone.text}">${escapeHTML(state)}</span>
                            </div>
                            <span class="text-muted">${count} (${percent}%)</span>
                          </div>
                          <div class="h-2 overflow-hidden rounded-full bg-white/10">
                            <div class="h-full rounded-full ${tone.dot}" style="width: ${percent}%"></div>
                          </div>
                        </div>
                      `;
                    })
                    .join("")}
                </div>
              </div>

              <div class="rounded-xl border border-white/20 bg-white/10 p-5 backdrop-blur-xl">
                <p class="text-sm uppercase tracking-wide text-muted">Connector Mix</p>
                <div class="mt-4 space-y-3">
                  ${typeRows
                    .map(([type, count]) => {
                      const percent = formatPercent(count, totalCount);

                      return `
                        <div class="rounded-lg border border-white/10 bg-white/5 p-3">
                          <div class="mb-2 flex items-center justify-between gap-3">
                            <span class="font-semibold capitalize">${escapeHTML(type)}</span>
                            <span class="text-sm text-muted">${count} (${percent}%)</span>
                          </div>
                          <div class="h-2 overflow-hidden rounded-full bg-white/10">
                            <div class="h-full rounded-full bg-accent" style="width: ${percent}%"></div>
                          </div>
                        </div>
                      `;
                    })
                    .join("")}
                </div>
              </div>
            </div>

            <details class="rounded-xl border border-white/20 bg-white/10 backdrop-blur-xl">
              <summary class="cursor-pointer list-none p-5">
                <div class="flex flex-col gap-2 md:flex-row md:items-center md:justify-between">
                  <div>
                    <p class="text-sm uppercase tracking-wide text-muted">Anonymized Connector Inventory</p>
                    <p class="mt-1 font-semibold">Encrypted IDs are available for audit-style review</p>
                  </div>
                  <span class="text-sm text-accent">View table</span>
                </div>
              </summary>
              <div class="border-t border-white/10 p-5">
                <div class="max-h-96 overflow-auto rounded-lg border border-white/10">
                  <table class="w-full min-w-[34rem] text-left text-sm">
                    <thead class="sticky top-0 bg-base-100/95 text-xs uppercase tracking-wide text-muted backdrop-blur">
                      <tr>
                        <th class="px-4 py-3 font-semibold">Encrypted ID</th>
                        <th class="px-4 py-3 font-semibold">Type</th>
                        <th class="px-4 py-3 font-semibold">State</th>
                      </tr>
                    </thead>
                    <tbody class="divide-y divide-white/10">
                      ${sortedConnectors
                        .map((connector) => {
                          const tone = stateTone(connector.state);

                          return `
                            <tr class="hover:bg-white/5">
                              <td class="px-4 py-3 font-mono text-xs md:text-sm">${escapeHTML(connector.name)}</td>
                              <td class="px-4 py-3">
                                <span class="rounded bg-white/10 px-2 py-1 text-xs text-muted">${escapeHTML(connector.type)}</span>
                              </td>
                              <td class="px-4 py-3">
                                <span class="inline-flex items-center gap-2 rounded-full border ${tone.border} ${tone.bg} px-2.5 py-1 text-xs font-semibold ${tone.text}">
                                  <span class="h-2 w-2 rounded-full ${tone.dot}"></span>
                                  ${escapeHTML(connector.state)}
                                </span>
                              </td>
                            </tr>
                          `;
                        })
                        .join("")}
                    </tbody>
                  </table>
                </div>
              </div>
            </details>
          `;
        }
      } catch (error) {
        console.error("Error fetching connector status:", error);
        errorContainer.classList.remove("hidden");
        const errorMessage = document.getElementById("errorMessage");
        if (errorMessage) {
          errorMessage.textContent =
            error instanceof Error ? error.message : "Unknown error occurred";
        }
        statusContainer.innerHTML = "";
      } finally {
        refreshBtn.removeAttribute("disabled");
      }
    }

    // Make function available globally for the refresh button
    (window as any).fetchConnectorStatus = fetchConnectorStatus;

    // Status loaded via button click
  </script>
</Layout>
